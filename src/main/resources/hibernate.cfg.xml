<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<!--
    Hibernate Configuration File (hibernate.cfg.xml)

    This file is used to configure Hibernate ORM and establish
    connection between the Java application and the database.

    It contains:
    - Database connection details (URL, username, password)
    - JDBC driver configuration
    - Hibernate dialect settings
    - Schema generation/update settings
    - SQL logging options
    - Entity class mappings

    Hibernate reads this file while creating the SessionFactory,
    which is used to perform database operations efficiently.
-->

<hibernate-configuration>
    <session-factory>

        <!-- ✅ Connection Properties -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/patientManagementSystem</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">Ekta@1204</property>

        <!-- ✅ Hibernate dialect -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <!-- ✅ Schema handling -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- ✅ Logging -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>


        <mapping class = "com.PMS.Main" />



    </session-factory>
</hibernate-configuration>
